Options -Indexes -MultiViews
DirectorySlash Off

RewriteEngine On

# Normalize directory URLs to a single canonical HTTPS URL with trailing slash.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI}/ [R=301,L,NE]

# Force HTTPS (works both behind proxy and on direct HTTPS).
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]

# Serve existing files/directories as-is.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# MODX: /api-feedback, /api/* и админка фидбека (до SPA fallback).
# Без этого POST с сайта и из приложения «Алфавиты» получают 404 вместо MODX.
RewriteRule ^api-feedback$ /modx/index.php?q=api-feedback [L,QSA]
RewriteRule ^admin-feedback$ /modx/index.php?q=admin-feedback [L,QSA]
RewriteRule ^api$ /modx/index.php [L]
RewriteRule ^api/?(.*)$ /modx/index.php?q=$1 [L,QSA]

# Known SPA routes fall back to the app shell.
RewriteRule ^(?:services(?:/.*)?|about|projects|ai-comparison|alphabet-project|catalog|feedback-form|test)/?$ /index.html [L]

# Unknown paths should be real 404 responses.
ErrorDocument 404 /404.html
RewriteCond %{REQUEST_URI} !^/(?:api|api-feedback|modx)(?:/|$)
RewriteRule ^ - [R=404,L]
